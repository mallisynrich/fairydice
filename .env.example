# ======================================================
# FairyDice .env.example
# ======================================================
# Copy this file to `.env` or `.env.local` and fill in values.
# DO NOT commit actual secrets (tokens, passwords) to git.
# ======================================================

# ------------------------
# Core Next.js runtime
# ------------------------

# Node environment. Common values: development, production, test.
NODE_ENV=development

# Port the app runs on inside Docker (forwarded to host in compose).
PORT=3000

# Disable telemetry collection by Next.js (recommended for FOSS).
NEXT_TELEMETRY_DISABLED=1

# ------------------------
# API / Auth / Security
# ------------------------

# Secret key used for signing cookies or JWTs.
# In production, generate a strong random string.
AUTH_SECRET=replace-me-with-random-hex

# Allowed origins for CORS. Comma-separated list.
# e.g., http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN=http://localhost:3000

# Cookie settings. Use "Strict" or "Lax".
COOKIE_SAMESITE=Strict

# ------------------------
# Analytics / Observability
# ------------------------

# Toggle custom analytics reporting (true/false).
ENABLE_ANALYTICS=false

# OpenTelemetry collector endpoint (if used).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ------------------------
# PlayCanvas integration
# ------------------------

# Public API key or project ID for PlayCanvas (not secret).
PLAYCANVAS_PROJECT_ID=replace-me

# ------------------------
# Database (if/when added)
# ------------------------

# Example Postgres URL; replace with your actual DSN.
DATABASE_URL=postgres://user:password@db:5432/fairydice

# ------------------------
# Misc / Developer Ergonomics
# ------------------------

# Enable polling for file watchers in Docker environments.
# Required for hot reload on Mac/Windows (Docker Desktop).
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
NEXT_WEBPACK_USEPOLLING=true

# Verbose logging toggle (true/false).
DEBUG=false

# ======================================================
# End of .env.example
# ======================================================
