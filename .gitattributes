# Normalize all text files to LF
 * text=auto eol=lf

# Shell scripts must always use LF
 *.sh text eol=lf

# Lockfiles prefer "ours" merge to avoid churn
 pnpm-lock.yaml merge=ours

# Treat docs as documentation in GitHub linguist
 *.org linguist-documentation
 *.md linguist-documentation
 docs/** linguist-documentation

# Binary files (images, fonts) should not be altered
 *.png binary
 *.jpg binary
 *.jpeg binary
 *.gif binary
 *.svg binary
 *.woff binary
 *.woff2 binary
